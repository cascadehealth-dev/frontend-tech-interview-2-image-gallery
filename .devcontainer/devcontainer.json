{
  "name": "Cascade Frontend Interview — Tech 2",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "npm install && cd mock-api && npm install",
  "postStartCommand": {
    "mock-api": "cd mock-api && npx tsx server.ts",
    "vite": "npm run dev"
  },
  "forwardPorts": [5173, 3001],
  "portsAttributes": {
    "5173": { "label": "Vite Dev Server", "onAutoForward": "openBrowser" },
    "3001": { "label": "Mock API", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "github.copilot.enable": { "*": false }
      },
      "extensions": [
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
